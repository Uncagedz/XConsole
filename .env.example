# Shared local development
DATABASE_URL=postgresql://xconsole:xconsole@127.0.0.1:5432/xconsole?schema=public
REDIS_URL=redis://127.0.0.1:6379

# Gateway
PORT=3001
XCONSOLE_API_TOKEN=replace-with-at-least-32-random-characters
XCONSOLE_DASHBOARD_SESSION_SECRET=replace-with-a-different-32-character-random-secret
XCONSOLE_DASHBOARD_SESSION_TTL_HOURS=12
XCONSOLE_DEVICE_REGISTRATION_CODE=replace-with-one-time-registration-code
XCONSOLE_ALLOW_INSECURE_DEV=false
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Explicit extension origins only, for example chrome-extension://abcdefghijklmnop...
CHROME_EXTENSION_ORIGINS=

# AI API
API_PORT=3000
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_PEPPER=replace-with-at-least-32-random-characters
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=900
XCONSOLE_GATEWAY_URL=http://127.0.0.1:3001
XCONSOLE_GATEWAY_TOKEN=replace-with-the-same-gateway-api-token

# Dashboard public configuration (the API token is for local development only)
VITE_GATEWAY_API_URL=http://127.0.0.1:3001
VITE_XCONSOLE_API_TOKEN=
VITE_API_BASE_URL=http://127.0.0.1:3000

# Legacy adapter (never commit real values; no default credentials are created)
LEGACY_AUTOMATION_API_URL=http://127.0.0.1:8100
LEGACY_INVENTORY_CACHE_TTL_MS=30000
XCONSOLE_BASIC_AUTH_USER=
XCONSOLE_BASIC_AUTH_PASSWORD=
# Set a separate random 32+ character value in deployed/multi-process use.
XCONSOLE_SESSION_SECRET=
# Used by connector wrappers as: Authorization: Bearer <token>
XCONSOLE_LEGACY_API_TOKEN=
DEALERSHIP_INVENTORY_URL=
DEALERSHIP_NEW_INVENTORY_URL=
DEALERSHIP_LIFTED_TRUCKS_URL=
FACEBOOK_CHROME_PROFILE_DIR=
FACEBOOK_COOKIE_FILE=
CHROME_BINARY=
CHROMEDRIVER_PATH=
BANK_DOCS_ROOT=
XCONSOLE_STATE_DIR=
JD_POWER_VALUATIONS_PATH=

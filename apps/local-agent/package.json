{
  "name": "@xconsole/local-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts run",
    "start": "node dist/index.js run",
    "record": "tsx src/index.ts record",
    "register": "tsx src/index.ts register",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@drivecentric-ai/shared": "workspace:*",
    "@xconsole/connectors": "workspace:*",
    "playwright-core": "^1.55.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}

{
  "manifest_version": 3,
  "name": "AI Sales Assistant for Dealerships",
  "short_name": "Sales AI",
  "version": "0.1.58",

  "description": "Human AI assistant for dealership teams. Reads lead context, summarizes needs, and drafts natural sales replies.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite",
    "sidePanel",
    "tabs",
    "audioCapture",
    "offscreen"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://aniextension.up.railway.app/*",
    "https://*.onrender.com/*",
    "https://www.tavernachryslerdodgejeepramfiat.com/*"
  ],

  "action": {
    "default_title": "AI Sales Assistant",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.drivecentric.com/*",
        "https://www.tavernachryslerdodgejeepramfiat.com/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "mic.html",
        "popup.html",
        "sidebar.html",
        "assets/mic-window.js",
        "assets/content.js",
        "assets/background.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/drivecentric_ai?schema=public
API_PORT=3000
ADMIN_WEB_ORIGIN=http://localhost:5173
EXTENSION_ORIGIN=chrome-extension://replace-after-install
CORS_ORIGINS=
JWT_ACCESS_SECRET=replace-with-at-least-32-random-chars
JWT_REFRESH_PEPPER=replace-with-at-least-32-random-chars
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=900
# Creative reply controls. Unsupported model parameters are automatically retried without them.
AI_TEMPERATURE=1.5
AI_REASONING_EFFORT=high
AI_RESPONSE_VARIETY=true

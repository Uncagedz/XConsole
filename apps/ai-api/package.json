{
  "name": "@xconsole/ai-api",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:local": "tsx watch src/local-server.ts",
    "start:local": "tsx src/local-server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "prisma:generate": "prisma generate --schema ../../packages/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../../packages/database/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema ../../packages/database/prisma/schema.prisma",
    "prisma:seed": "tsx ../../packages/database/prisma/seed.ts"
  },
  "dependencies": {
    "@drivecentric-ai/config": "workspace:*",
    "@drivecentric-ai/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "vitest": "^2.1.9"
  },
  "prisma": {
    "schema": "../../packages/database/prisma/schema.prisma"
  }
}

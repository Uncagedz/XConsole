{
  "name": "@xconsole/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "prisma generate --schema prisma/schema.prisma",
    "validate": "prisma validate --schema prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "audit": "node scripts/audit.mjs",
    "seed": "tsx prisma/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
